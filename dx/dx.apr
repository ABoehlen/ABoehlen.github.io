(SEd.3934
	Name:	"View.Flip"
	Creator:	"adrian"
	CreationDate:	"Fre 31 Jan 2014 21:00:56 CET"
	GUIName:	"Script"
	Win:	3935
	CSMgr:	3936
	DocExts:	3937
	Source:	"theView=av.getactivedoc\nif(theView.getthemes.count=0)then return nil end\nif(theView.getactivethemes.count=0)then return nil end\ntheTheme=theView.getactivethemes.get(0)\ntheftab=theTheme.getftab\nshapefeld=theFtab.findfield(\"Shape\")\nif (shapefeld=nil) then return nil end\nif (shapefeld.gettype=#FIELD_SHAPELINE) then\nif (thetheme.canexporttoftab.not) then return nil end\nif (thetheme.hastable.not) then return nil end\nif (thetheme.getftab.iseditable.not) then av.run(\"View.toggleediting\",\"\") end'return nil end\nthef
tab=theTheme.getftab\nthebitmap=theftab.getselection\nz=thebitmap.count\nif (thebitmap.count=0)then return nil end\n\nfor each x in theBitmap\n      anewgraphic=theftab.returnvalue(shapefeld, x).flip\n      theftab.setvalue(theftab.findfield(\"Shape\"),x,anewgraphic)\nend\ntheview.getdisplay.invalidate(true)\n'thetheme.getftab.seteditable(false)\nend\n"
)

