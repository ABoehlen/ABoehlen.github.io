)

(SEd.2117
	Name:	"View.Move"
	Creator:	"adrian"
	CreationDate:	"Son 10 Feb 2013 19:06:06 CET"
	GUIName:	"Script"
	Win:	2118
	CSMgr:	2119
	DocExts:	2120
	Source:	"'Set this script as click script for an popup item\n'Setzen Sie dieses Script als Clickscript für einen neuen Menüeintrag im Popup-Menü des View\n\ntheview=av.getactivedoc\ndisp=theview.getdisplay\nvisext=disp.ReturnVisExtent\nup=disp.returnuserpoint\nhoehebreite=visext.returnsize\nbreite=hoehebreite.getx\nhoehe=hoehebreite.gety\nlinks=visext.getleft\n\nunten=visext.getbottom\n\nuserx=up.getx\nusery=up.gety\n\nAbstoben=(usery-visext.gettop).abs\nAbstlinks=(userx-visext.getleft).abs\na=links-(breite-(abstlinks*2))\nb=unten+(hoe
he-(abstoben*2))\nporigin=(a@b)\npsize=(breite@hoehe)\nr=rect.make(porigin,psize).returncenter\nvisext.setorigin(a@b)\ndisp.panto(r)\n\n\n"
)

