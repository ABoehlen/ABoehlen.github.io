(SEd.1724
	Name:	"calc_dist_from_qth"
	CreationDate:	"Samstag, 15. Februar 2025 11:26:36"
	GUIName:	"Script"
	Win:	1725
	CSMgr:	1726
	DocExts:	1727
	Source:	"'##############################################################\n'#\n'# Filename:     calc_dist_from_qth.ave\n'# Author:       Adrian Boehlen\n'# Date:         15.02.2025\n'# Version:      1.0\n'#\n'# Purpose:      Berechnet die Distanz jedes Sendestandortes\n'#               vom QTH\n'#                 \n'##############################################################\n\n'# X/Y-Koordinaten des QTH (CH1903 LV03)\nqthX = 610555\nqthY = 197233\n\n'# ein View muss aktiv sein\ntheView = av.GetActiveDoc\n\n'# lokale Variablen\ntheTh
eme = theView.GetActiveThemes.Get(0)\ntheFTab = theTheme.GetFTab\nxField = theFTab.FindField(\"Metx\")\nyField = theFTab.FindField(\"Mety\")\ndistField = theFTab.FindField(\"Dist\")\n\n'# pruefen, ob das Thema bearbeitbar und im Bearbeitungsmodus ist\nif (theFTab.canEdit.Not) then\n  MsgBox.Warning(\"The table cannot be edited\", \"Abort\")\n  return nil\nend\n\nif (theFTab.isEditable.Not) then\n  MsgBox.Warning(\"Please start an edit session first\", \"Abort\")\n  return nil\nend\n\n'# jede Zeile durchgehen\nfor each rec in theFTab\n  xCo
ord = theFTab.returnValue(xField, rec)\n  yCoord = theFTab.returnValue(yField, rec)\n  \n  '# Differenz der X- und Y-Koordinate berechnen\n  if (qthX > xCoord) then\n    xDiff = qthX - xCoord\n  else\n    xDiff = xCoord - qthX\n  end\n\n  if (qthY > yCoord) then\n    yDiff = qthY - yCoord\n  else\n    yDiff = yCoord - qthY\n  end\n  \n  '# Distanz gemaess Pythagoras berechnen und als gerundeten km-Wert speichern\n  dist = ((xDiff ^ 2) + (yDiff ^ 2)).Sqrt\n  dist = dist/1000\n  dist.SetFormat(\"d\")\n  \n  '# Distanz in km ins ent
sprechende Feld schreiben\n  theFTab.SetValueNumber(distField, rec, dist)\nend"
)

