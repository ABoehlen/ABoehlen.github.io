(SEd.2173
	Name:	"View.Flip"
	Creator:	"adrian"
	CreationDate:	"Fre 31 Jan 2014 21:00:56 CET"
	GUIName:	"Script"
	Win:	2174
	CSMgr:	2175
	DocExts:	2176
	Source:	"theView=av.getactivedoc\nif(theView.getthemes.count=0)then return nil end\nif(theView.getactivethemes.count=0)then return nil end\ntheTheme=theView.getactivethemes.get(0)\ntheftab=theTheme.getftab\nshapefeld=theFtab.findfield(\"Shape\")\nif (shapefeld=nil) then return nil end\nif (shapefeld.gettype=#FIELD_SHAPELINE) then\nif (thetheme.canexporttoftab.not) then return nil end\nif (thetheme.hastable.not) then return nil end\nif (thetheme.getftab.iseditable.not) then av.run(\"View.toggleediting\",\"\") end'return nil end\nthef
tab=theTheme.getftab\nthebitmap=theftab.getselection\nz=thebitmap.count\nif (thebitmap.count=0)then return nil end\n\nfor each x in theBitmap\n      anewgraphic=theftab.returnvalue(shapefeld, x).flip\n      theftab.setvalue(theftab.findfield(\"Shape\"),x,anewgraphic)\nend\ntheview.getdisplay.invalidate(true)\n'thetheme.getftab.seteditable(false)\nend\n"
)

(DocWin.2174
	Owner:	2173
	X:	330
	Y:	105
	W:	634
	H:	450
)

(CSMgr.2175
)

(DocAct.2176
	Doc:	2173
)

(SEd.2177
	Name:	"View.LineTool"
	Creator:	"adrian"
	CreationDate:	"Son 10 Feb 2013 18:51:26 CET"
	GUIName:	"Script"
	Win:	2178
	CSMgr:	2179
	DocExts:	2180
	Source:	"'View.LineTool\n\n'@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@\n'@@@ This is the system script View.LineTool.\n'@@@ It runs when you apply the Draw Straight Line\n'@@@ tool to the View's display.\n'@@@ It has been modified so that it will\n'@@@ tell the user the azimuth of the line \n'@@@ he or she draws.\n'@@@ See ReturnLineSegmentAzimuth for more details.\n'@@@ \n'@@@ TO MAKE THIS SCRIPT WORK:\n'@@@ Download this script and the ReturnLineSegmentAzimuth script (they come in a .zip file together).\n'@@@ Put each in a Script 
Editor document (to make a new script editor document, double-click the Scripts icon in the Project window).\n'@@@ Name this one View.LineTool and the other ReturnLineSegmentAzimuth (do this by choosing Script-->Properties and entering the name in the Name: textfield.).\n'@@@ [This script will run instead of the system View.LineTool script if you name it View.LineTool and compile it]\n'@@@ Compile them both (click the Compile button).\n'@@@ Make the View active and use the Draw Straight Line tool (it is in the 
tool menu under the Draw Point tool).  This will not work if you are editing a theme.\n'@@@ \n'@@@ By David F. Kimball 11/2000\n'@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@\n\ntheView = av.GetActiveDoc\nl = theView.ReturnUserLine\n\nif (l.IsNull) then\n  return nil\nend\n\n'@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@\n'@@@ THIS IS THE ADDED PART:\ngeoGrad = av.Run(\"ReturnLineSegmentAzimuth\",{l.ReturnStart,l.ReturnEnd})\nariGrad = 360 - (geoGrad - 90)\nMsgBox.Info(\"Azimuth:\" + 10.AsChar + geoGrad.AsString ++ \n\"geographic grads\" + 10.
AsChar + ariGrad.AsString ++ \"arithmetic grads\",\"Azimuth of line\")\n'@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@\n\n\n"
)

